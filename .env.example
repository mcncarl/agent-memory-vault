# Copy this file to .env for local use.
# Keep .env local and private.
# Agent Memory Vault accepts the AGENT_MEMORY_* namespace only.

AGENT_MEMORY_ROOT=/path/to/your/agent-memory-vault
AGENT_MEMORY_GIT_ROOT=/path/to/git-root-containing-the-vault
AGENT_MEMORY_CONFIG_ROOT=$HOME/.config/agent-memory
AGENT_MEMORY_STATE_DB=$HOME/.config/agent-memory/state.sqlite
AGENT_MEMORY_USER_ID=demo-user
AGENT_MEMORY_AGENT_ID=shared
AGENT_MEMORY_APP_ID=agent-memory
MEMORY_ACTOR=codex
AGENT_MEMORY_AUDIT_DB=$HOME/.config/agent-memory/audit_decisions.sqlite
AGENT_MEMORY_CLOSEOUT_LOG=$HOME/.config/agent-memory/logs/closeout.jsonl
AGENT_MEMORY_AUDIT_RUN_LOG=$HOME/.config/agent-memory/logs/audit_runs.jsonl
AGENT_MEMORY_AUDIT_REPORT=$HOME/.config/agent-memory/reports/latest-audit.json
AGENT_MEMORY_INVARIANTS=$HOME/.config/agent-memory/config/system-invariants.json
AGENT_MEMORY_PYTHON=python3

# Optional semantic retrieval layer. Keep generated vector data local.
AGENT_MEMORY_ZVEC_PYTHON=python3
AGENT_MEMORY_VECTOR_DIR=$HOME/.config/agent-memory/zvec/memory_chunks_embeddinggemma_768
AGENT_MEMORY_EMBEDDING_MODEL=google/embeddinggemma-300m
AGENT_MEMORY_EMBEDDING_DIM=768
AGENT_MEMORY_EMBEDDING_DEVICE=cpu
AGENT_MEMORY_REQUIRE_LOCAL_MODEL=false
AGENT_MEMORY_MODEL_MANIFEST=$HOME/.config/agent-memory/models/embeddinggemma-300m/model-manifest.json
AGENT_MEMORY_MODEL_REVISION=
AGENT_MEMORY_DEPENDENCY_LOCK=$HOME/.config/agent-memory/requirements-vector.lock

# Optional, only if you later add an LLM-based closeout/reflection step.
# DEEPSEEK_API_KEY=replace_with_your_private_key
